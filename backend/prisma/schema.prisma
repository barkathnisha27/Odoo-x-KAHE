generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String
  password_hash String
  role          String   @default("user") // 'user' | 'admin'
  created_at    DateTime @default(now())
  trips         Trip[]
  profile       Profile?
}

model Profile {
  id               String  @id @default(uuid())
  user_id          String  @unique
  avatar           String?
  bio              String?
  home_currency    String  @default("USD")
  preferred_region String?
  preferences      Json?   @default("{}")
  user             User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model City {
  id               String     @id @default(uuid())
  name             String
  country          String
  region           String
  description      String
  image_url        String
  flag_emoji       String
  avg_daily_cost   Float
  popularity_score Int
  stops            TripStop[]
  activities       Activity[]
}

model Activity {
  id               String         @id @default(uuid())
  city_id          String
  title            String
  category         String
  duration_minutes Int
  price            Float
  rating           Float
  image_url        String
  description      String
  city             City           @relation(fields: [city_id], references: [id])
  tripActivities   TripActivity[]
}

model Trip {
  id             String        @id @default(uuid())
  user_id        String
  title          String
  description    String?
  destination    String?
  cover_image    String?
  start_date     DateTime
  end_date       DateTime
  traveler_count Int           @default(1)
  status         String        @default("upcoming") // 'draft', 'upcoming', 'active', 'completed', 'cancelled'
  trip_type      String        @default("solo")
  visibility     String        @default("private") // 'private' | 'public'
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt
  user           User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  stops          TripStop[]
  budgets        Budget[]
  packing_items  PackingItem[]
  shared_trips   SharedTrip[]
}

model TripStop {
  id             String         @id @default(uuid())
  trip_id        String
  city_id        String
  day_number     Int
  order_index    Int
  arrival_date   DateTime
  departure_date DateTime
  transport_mode String
  notes          String?
  trip           Trip           @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  city           City           @relation(fields: [city_id], references: [id])
  activities     TripActivity[]
}

model TripActivity {
  id           String   @id @default(uuid())
  trip_stop_id String
  activity_id  String
  day_date     DateTime
  time_slot    String
  custom_note  String?
  trip_stop    TripStop @relation(fields: [trip_stop_id], references: [id], onDelete: Cascade)
  activity     Activity @relation(fields: [activity_id], references: [id])
}

model Budget {
  id           String @id @default(uuid())
  trip_id      String
  category     String
  amount       Float  @default(0)
  spent_amount Float  @default(0)
  trip         Trip   @relation(fields: [trip_id], references: [id], onDelete: Cascade)

  @@unique([trip_id, category])
}

model PackingItem {
  id         String   @id @default(uuid())
  trip_id    String
  item_name  String
  completed  Boolean  @default(false)
  category   String?
  created_at DateTime @default(now())
  trip       Trip     @relation(fields: [trip_id], references: [id], onDelete: Cascade)
}

model SharedTrip {
  id         String   @id @default(uuid())
  trip_id    String
  slug       String   @unique
  created_at DateTime @default(now())
  trip       Trip     @relation(fields: [trip_id], references: [id], onDelete: Cascade)
}
